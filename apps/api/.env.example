# Server
NODE_ENV=development
PORT=3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Firebase Admin SDK (JSON string of the service account)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Google Maps (server-side Geocoding API key - NEVER expose to client)
GOOGLE_MAPS_API_KEY=your-google-maps-geocoding-api-key

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key

# CORS - comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://citizen.sahayi.in

# Sentry (optional in development)
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0
